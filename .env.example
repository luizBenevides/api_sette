# --- SEGURANCA API EXTERNA (SPACECOM) ---
SPACECOM_SISTEMA=sette
SPACECOM_RUIDO=coloque_o_valor_aqui
SPACECOM_CHAVE_API=coloque_o_valor_aqui
URL_BASE_SPACECOM=https://sisgem-dev.spacecom.com.br/api/v2

# --- CONFIGURACAO DA JIGA LOCAL ---
NOME_JIGA=JIGA_SETTE_01

DB_URL=postgresql://usuario:senha@localhost:5432/log_sette

# --- FALLBACK ---
ARQUIVO_EMERGENCIA=logs_emergencia.txt

# --- LEITOR (MODO HEADLESS) ---
# INPUT_MODE: auto | hid | serial
INPUT_MODE=auto

# Para leitor tipo teclado USB (HID), descubra com:
# ls -l /dev/input/by-id/
# e aponte para /dev/input/eventX correspondente.
HID_DEVICE=/dev/input/event0

# Para leitor serial de porta tty
SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUDRATE=9600
SERIAL_TIMEOUT=1
